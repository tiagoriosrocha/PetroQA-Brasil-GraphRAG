    pq:sourceURL """https://publicacoesup.petrobras.com.br/peld/catalog/book/12/chapter/22""" ;
    pq:sourceIndex "1"^^xsd:integer .

src:s_q059_2 a pq:Source ;
    pq:sourceURL """https://pt.wikipedia.org/wiki/Geologia_do_petr%C3%B3leo""" ;
    pq:sourceIndex "2"^^xsd:integer .

evid:ev_q059_1 a pq:Evidence ;
    pq:evidenceText """O primeiro poço perfurado na área, após a assinatura do contrato, foi o W731, que confirmou a continuidade dos reservatórios identificados no poço 2-ANP-2A-RJS, na porção Noroeste (NW) da estrutura de Libra.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Mero: caracterização dos reservatórios e desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q059_1 .
q:q059 pq:hasEvidence evid:ev_q059_1 .
evid:ev_q059_1 pq:supportsQuestion q:q059 .

evid:ev_q059_2 a pq:Evidence ;
    pq:evidenceText """No entanto, o segundo poço perfurado, o W735, localiza- do em seu compartimento central, identificou fluido e regime de pressão diferentes daqueles observados nos poços 2-ANP-2A-RJS e W731, configurando uma compartimentação importante na área e direcionando o Plano de Avaliação para a porção NW do bloco.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Mero: caracterização dos reservatórios e desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q059_2 .
q:q059 pq:hasEvidence evid:ev_q059_2 .
evid:ev_q059_2 pq:supportsQuestion q:q059 .

evid:ev_q059_3 a pq:Evidence ;
    pq:evidenceText """Finalmente, estudos de migração revelam informação sobre como hidrocarbonetos movem-se da fonte ao reservatório e ajudam a quantificar a fonte (ou "a cozinha") dos hidrocarbonetos em uma área em particular.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q059_2 .
q:q059 pq:hasEvidence evid:ev_q059_3 .
evid:ev_q059_3 pq:supportsQuestion q:q059 .


