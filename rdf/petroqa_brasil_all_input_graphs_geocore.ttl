evid:ev_q075_1 a pq:Evidence ;
    pq:evidenceText """Reconhece-se quatro estágios geológicos evolutivos na bacia de Campos, que são pré-rifte (continental), rifte (continental), proto-oceânico (transicional evaporítico) e drift (marinho).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Bacia de Campos | Wikipédia""" ;
    pq:fromSource src:s_q075_1 .
q:q075 pq:hasEvidence evid:ev_q075_1 .
evid:ev_q075_1 pq:supportsQuestion q:q075 .

evid:ev_q075_2 a pq:Evidence ;
    pq:evidenceText """Na visão tradicional, evaporito ou depósito salino é uma rocha sedimentar formada pela cristalização e precipitação química dos sais dissolvidos em um meio aquoso, devido a um processo de evaporação.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Evaporito | Wikipédia""" ;
    pq:fromSource src:s_q075_2 .
q:q075 pq:hasEvidence evid:ev_q075_2 .
evid:ev_q075_2 pq:supportsQuestion q:q075 .

evid:ev_q075_3 a pq:Evidence ;
    pq:evidenceText """Seu ambiente de formação são bacias fechadas sujeitas a evaporação intensa.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Evaporito | Wikipédia""" ;
    pq:fromSource src:s_q075_2 .
q:q075 pq:hasEvidence evid:ev_q075_3 .
evid:ev_q075_3 pq:supportsQuestion q:q075 .


