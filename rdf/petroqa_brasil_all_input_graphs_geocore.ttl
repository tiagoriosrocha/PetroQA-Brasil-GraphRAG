evid:ev_q028_1 a pq:Evidence ;
    pq:evidenceText """Nas regiões mais profundas destes lagos começaram a acumular grandes quantidades de matéria orgânica de algas microscópicas.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q028_1 .
q:q028 pq:hasEvidence evid:ev_q028_1 .
evid:ev_q028_1 pq:supportsQuestion q:q028 .

evid:ev_q028_2 a pq:Evidence ;
    pq:evidenceText """Esta matéria orgânica, misturada a sedimentos, formou o que são as rochas que geram o óleo e o gás do pré-sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q028_2 .
q:q028 pq:hasEvidence evid:ev_q028_2 .
evid:ev_q028_2 pq:supportsQuestion q:q028 .

evid:ev_q028_3 a pq:Evidence ;
    pq:evidenceText """Nas partes mais rasas destes lagos, em grandes ilhas lacustres, surgiram as chamadas conchas calcárias que se acumularam cada vez mais com o passar do tempo.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q028_2 .
q:q028 pq:hasEvidence evid:ev_q028_3 .
evid:ev_q028_3 pq:supportsQuestion q:q028 .

evid:ev_q028_4 a pq:Evidence ;
    pq:evidenceText """Tanto as conchas calcárias quanto as rochas calcárias compõem os principais reservatórios do pré-sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q028_2 .
q:q028 pq:hasEvidence evid:ev_q028_4 .
evid:ev_q028_4 pq:supportsQuestion q:q028 .

evid:ev_q028_5 a pq:Evidence ;
    pq:evidenceText """Sistema petrolífero é um modelo que engloba todos os elementos e processos geológicos necessários à existência de acumulações de óleo e gás.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q028_2 .
q:q028 pq:hasEvidence evid:ev_q028_5 .
evid:ev_q028_5 pq:supportsQuestion q:q028 .

evid:ev_q028_6 a pq:Evidence ;
    pq:evidenceText """Para que estas acumulações ocorram, necessita-se de rochas geradoras maduras, rocha reservatório, rocha selante e a sobrecarga.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q028_2 .
q:q028 pq:hasEvidence evid:ev_q028_6 .
evid:ev_q028_6 pq:supportsQuestion q:q028 .


