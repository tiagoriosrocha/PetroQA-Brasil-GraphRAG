evid:ev_q053_1 a pq:Evidence ;
    pq:evidenceText """Os desafios de caracterização desses reservatórios envolvem a integração dos estudos de sísmica, dados de poços, petrografia, interpretações de processos deposicionais e diagenéticos, assim como os resultados de testes de produtividade e injetividades das rochas.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Búzios: a jornada desde a caracterização dos reservatórios ao início do desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q053_1 .
q:q053 pq:hasEvidence evid:ev_q053_1 .
evid:ev_q053_1 pq:supportsQuestion q:q053 .

evid:ev_q053_2 a pq:Evidence ;
    pq:evidenceText """A análise de reservatórios no mais simples nível requer uma avaliação da sua porosidade (para calcular o volume de hidrocarbonetos in situ) e sua permeabilidade (para calcular quão facilmente os hidrocarbonetos irão fluir fora dele).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q053_2 .
q:q053 pq:hasEvidence evid:ev_q053_2 .
evid:ev_q053_2 pq:supportsQuestion q:q053 .


