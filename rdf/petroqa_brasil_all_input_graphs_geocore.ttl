    pq:sourceURL """https://petrobras.com.br/pre-sal""" ;
    pq:sourceIndex "2"^^xsd:integer .

evid:ev_q027_1 a pq:Evidence ;
    pq:evidenceText """Os reservatórios são rochas carbonáticas de origem lacustre (idade aptiana), depositadas durante o rifteamento oblíquo de abertura da Bacia de Santos e compreende às formações Itapema (Sequência K38) e Barra Velha (Sequências K44 e K46/K48).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Búzios: a jornada desde a caracterização dos reservatórios ao início do desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q027_1 .
q:q027 pq:hasEvidence evid:ev_q027_1 .
evid:ev_q027_1 pq:supportsQuestion q:q027 .

evid:ev_q027_2 a pq:Evidence ;
    pq:evidenceText """Nos altos estruturais, a Formação Itapema é composta majoritariamente por rudstones e grainstones de bivalves e a Formação Barra Velha, por estromatólitos, grainstones intraclásticos e esferulititos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Búzios: a jornada desde a caracterização dos reservatórios ao início do desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q027_2 .
q:q027 pq:hasEvidence evid:ev_q027_2 .
evid:ev_q027_2 pq:supportsQuestion q:q027 .

evid:ev_q027_3 a pq:Evidence ;
    pq:evidenceText """Mais pra frente, essas conchas 'ganharam a companhia' de depósitos de estromatólitos, que nada mais são do que tipos de algas que formam rochas calcárias.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q027_2 .
q:q027 pq:hasEvidence evid:ev_q027_3 .
evid:ev_q027_3 pq:supportsQuestion q:q027 .

evid:ev_q027_4 a pq:Evidence ;
    pq:evidenceText """Tanto as conchas calcárias quanto as rochas calcárias compõem os principais reservatórios do pré-sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q027_2 .
q:q027 pq:hasEvidence evid:ev_q027_4 .
evid:ev_q027_4 pq:supportsQuestion q:q027 .


