evid:ev_q094_1 a pq:Evidence ;
    pq:evidenceText """Para a maioria dos geólogos, um turbidito é uma camada com gradação grano-classificada consistindo num conjunto de estratos arenito/pelito que foram depositados por corrente de turbidez e é comumente coberta por pelitos hemipelágicos contendo assembléia de fósseis de águas profundas.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Turbidito | Wikipédia""" ;
    pq:fromSource src:s_q094_1 .
q:q094 pq:hasEvidence evid:ev_q094_1 .
evid:ev_q094_1 pq:supportsQuestion q:q094 .

evid:ev_q094_2 a pq:Evidence ;
    pq:evidenceText """Os depósitos se formam por fluxos hiperpicnais concentrados, constituindo sucessões de estratos sedimentares arenosos e pelágicos bastante espessos, num curto período de tempo geológico.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Turbidito | Wikipédia""" ;
    pq:fromSource src:s_q094_2 .
q:q094 pq:hasEvidence evid:ev_q094_2 .
evid:ev_q094_2 pq:supportsQuestion q:q094 .

evid:ev_q094_3 a pq:Evidence ;
    pq:evidenceText """Geralmente são compostas por granulometria de areia a seixo como arenitos, calcarenitos ou conglomerados.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q094_2 .
q:q094 pq:hasEvidence evid:ev_q094_3 .
evid:ev_q094_3 pq:supportsQuestion q:q094 .

evid:ev_q094_4 a pq:Evidence ;
    pq:evidenceText """As rochas selantes são rochas de baixa permeabilidade, como folhelhos, siltitos e calciculitos, de forma que impedem o escape dos fluidos da rocha reservatório.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
