evid:ev_q014_3 a pq:Evidence ;
    pq:evidenceText """Campos gigantes e supergigantes de alta produtividade na seção Pré-sal da Bacia de Santos são constituídos predominantemente por fácies carbonáticas lacustres e selados por espessa camada de evaporitos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Estratigrafia e modelos deposicionais carbonáticos do Pré-sal da Bacia de Santos | Universidade Petrobras""" ;
    pq:fromSource src:s_q014_2 .
