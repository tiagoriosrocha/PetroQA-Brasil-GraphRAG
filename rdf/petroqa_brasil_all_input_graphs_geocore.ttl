evid:ev_q002_1 a pq:Evidence ;
    pq:evidenceText """Campos gigantes e supergigantes de alta produtividade na seção Pré-sal da Bacia de Santos são constituídos predominantemente por fácies carbonáticas lacustres e selados por espessa camada de evaporitos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Estratigrafia e modelos deposicionais carbonáticos do Pré-sal da Bacia de Santos | Universidade Petrobras""" ;
    pq:fromSource src:s_q002_1 .
q:q002 pq:hasEvidence evid:ev_q002_1 .
evid:ev_q002_1 pq:supportsQuestion q:q002 .

evid:ev_q002_2 a pq:Evidence ;
    pq:evidenceText """O selo, ou rocha selante, é uma unidade com baixa permeabilidade que impede o escape de hidrocarbonetos da rocha reservatório.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q002_2 .
q:q002 pq:hasEvidence evid:ev_q002_2 .
evid:ev_q002_2 pq:supportsQuestion q:q002 .


