evid:ev_q010_1 a pq:Evidence ;
    pq:evidenceText """O que se chama de pré-sal são as rochas sedimentares que existem abaixo da uma camada de sal com até 2.000 m de espessura, que se estende por uma grande extensão.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q010_1 .
q:q010 pq:hasEvidence evid:ev_q010_1 .
evid:ev_q010_1 pq:supportsQuestion q:q010 .

evid:ev_q010_2 a pq:Evidence ;
    pq:evidenceText """Essa espessa camada de sal, formada principalmente de halita (cloreto de sódio, ou seja, o sal que usamos na comida) e anidrita (sulfato de cálcio) é uma barreira que se formou diretamente sobre a rocha geradora, impedindo que, neste caso, o petróleo migrasse.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q010_2 .
q:q010 pq:hasEvidence evid:ev_q010_2 .
evid:ev_q010_2 pq:supportsQuestion q:q010 .

evid:ev_q010_3 a pq:Evidence ;
    pq:evidenceText """As rochas selantes são rochas de baixa permeabilidade, como folhelhos, siltitos e calciculitos, de forma que impedem o escape dos fluidos da rocha reservatório.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q010_2 .
q:q010 pq:hasEvidence evid:ev_q010_3 .
evid:ev_q010_3 pq:supportsQuestion q:q010 .

evid:ev_q010_4 a pq:Evidence ;
    pq:evidenceText """Geralmente estas rochas situam-se acima do reservatório.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q010_2 .
q:q010 pq:hasEvidence evid:ev_q010_4 .
evid:ev_q010_4 pq:supportsQuestion q:q010 .


