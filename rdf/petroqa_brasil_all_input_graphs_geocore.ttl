evid:ev_q145_1 a pq:Evidence ;
    pq:evidenceText """Para a maioria dos geólogos, um turbidito é uma camada com gradação grano-classificada consistindo num conjunto de estratos arenito/pelito que foram depositados por corrente de turbidez e é comumente coberta por pelitos hemipelágicos contendo assembléia de fósseis de águas profundas.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Turbidito | Wikipédia""" ;
    pq:fromSource src:s_q145_1 .
q:q145 pq:hasEvidence evid:ev_q145_1 .
evid:ev_q145_1 pq:supportsQuestion q:q145 .

evid:ev_q145_2 a pq:Evidence ;
    pq:evidenceText """Os depósitos se formam por fluxos hiperpicnais concentrados, constituindo sucessões de estratos sedimentares arenosos e pelágicos bastante espessos, num curto período de tempo geológico.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Turbidito | Wikipédia""" ;
    pq:fromSource src:s_q145_2 .
q:q145 pq:hasEvidence evid:ev_q145_2 .
evid:ev_q145_2 pq:supportsQuestion q:q145 .

evid:ev_q145_3 a pq:Evidence ;
    pq:evidenceText """As sequências turbidíticas são muito procuradas pelos geólogos de petróleo por constituírem bons reservatórios para hidrocarbonetos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Turbidito | Wikipédia""" ;
    pq:fromSource src:s_q145_2 .
q:q145 pq:hasEvidence evid:ev_q145_3 .
evid:ev_q145_3 pq:supportsQuestion q:q145 .

evid:ev_q145_4 a pq:Evidence ;
    pq:evidenceText """O reservatório é uma unidade litológica porosa e permeável ou conjunto de unidade que retém as reservas de hidrocarbonetos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q145_2 .
q:q145 pq:hasEvidence evid:ev_q145_4 .
