evid:ev_q072_1 a pq:Evidence ;
    pq:evidenceText """A Bacia de Campos é uma bacia sedimentar brasileira situada na costa norte do estado do Rio de Janeiro, estendendo-se até o sul do estado do Espírito Santo, entre os paralelos 21 e 23 sul.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Bacia de Campos | Wikipédia""" ;
    pq:fromSource src:s_q072_1 .
q:q072 pq:hasEvidence evid:ev_q072_1 .
