evid:ev_q110_2 a pq:Evidence ;
    pq:evidenceText """A análise de reservatórios no mais simples nível requer uma avaliação da sua porosidade (para calcular o volume de hidrocarbonetos in situ) e sua permeabilidade (para calcular quão facilmente os hidrocarbonetos irão fluir fora dele).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q110_2 .
q:q110 pq:hasEvidence evid:ev_q110_2 .
evid:ev_q110_2 pq:supportsQuestion q:q110 .

evid:ev_q110_3 a pq:Evidence ;
    pq:evidenceText """A condição para o armazenamento do petróleo nas rochas reservatório é a porosidade de tais rochas, que variam de 5% a 35%, tendo em média de 15% a 30%.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q110_2 .
q:q110 pq:hasEvidence evid:ev_q110_3 .
