evid:ev_q046_1 a pq:Evidence ;
    pq:evidenceText """O Campo de Mero é uma importante área petrolífera na porção setentrional da Bacia de Santos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Mero: caracterização dos reservatórios e desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q046_1 .
q:q046 pq:hasEvidence evid:ev_q046_1 .
evid:ev_q046_1 pq:supportsQuestion q:q046 .

evid:ev_q046_2 a pq:Evidence ;
    pq:evidenceText """À época foram constatados reservatórios carbonáticos, pertencentes às Formações Barra Velha e Itapema, com excelentes qualidades permoporosa e uma coluna de óleo de cerca de 300 m.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Mero: caracterização dos reservatórios e desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q046_2 .
q:q046 pq:hasEvidence evid:ev_q046_2 .
evid:ev_q046_2 pq:supportsQuestion q:q046 .

evid:ev_q046_3 a pq:Evidence ;
    pq:evidenceText """Os reservatórios são rochas carbonáticas de origem lacustre (idade aptiana), depositadas durante o rifteamento oblíquo de abertura da Bacia de Santos e compreende às formações Itapema (Sequência K38) e Barra Velha (Sequências K44 e K46/K48).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Búzios: a jornada desde a caracterização dos reservatórios ao início do desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q046_2 .
q:q046 pq:hasEvidence evid:ev_q046_3 .
evid:ev_q046_3 pq:supportsQuestion q:q046 .


