evid:ev_q032_1 a pq:Evidence ;
    pq:evidenceText """O que se chama de pré-sal são as rochas sedimentares que existem abaixo da uma camada de sal com até 2.000 m de espessura, que se estende por uma grande extensão.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q032_1 .
q:q032 pq:hasEvidence evid:ev_q032_1 .
evid:ev_q032_1 pq:supportsQuestion q:q032 .

evid:ev_q032_2 a pq:Evidence ;
    pq:evidenceText """O prefixo pré-, portanto, refere-se ao tempo, não ao espaço.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q032_2 .
q:q032 pq:hasEvidence evid:ev_q032_2 .
evid:ev_q032_2 pq:supportsQuestion q:q032 .

evid:ev_q032_3 a pq:Evidence ;
    pq:evidenceText """Tais formações encontram-se a distâncias de cerca de 300 quilômetros da costa brasileira, em profundidades de aproximadamente 5 mil metros, sendo 2 mil de lâmina d’água, mil metros de sedimentos e outros 2 mil de sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal Bacia de Santos | Comunica Bacia de Santos | Petrobras""" ;
    pq:fromSource src:s_q032_2 .
q:q032 pq:hasEvidence evid:ev_q032_3 .
evid:ev_q032_3 pq:supportsQuestion q:q032 .


