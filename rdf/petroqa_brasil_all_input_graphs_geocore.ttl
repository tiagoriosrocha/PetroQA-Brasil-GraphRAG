evid:ev_q037_1 a pq:Evidence ;
    pq:evidenceText """O primeiro poço perfurado na área, após a assinatura do contrato, foi o W731, que confirmou a continuidade dos reservatórios identificados no poço 2-ANP-2A-RJS, na porção Noroeste (NW) da estrutura de Libra.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Mero: caracterização dos reservatórios e desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q037_1 .
q:q037 pq:hasEvidence evid:ev_q037_1 .
evid:ev_q037_1 pq:supportsQuestion q:q037 .

evid:ev_q037_2 a pq:Evidence ;
    pq:evidenceText """No entanto, o segundo poço perfurado, o W735, localiza- do em seu compartimento central, identificou fluido e regime de pressão diferentes daqueles observados nos poços 2-ANP-2A-RJS e W731, configurando uma compartimentação importante na área e direcionando o Plano de Avaliação para a porção NW do bloco.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Mero: caracterização dos reservatórios e desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q037_2 .
q:q037 pq:hasEvidence evid:ev_q037_2 .
evid:ev_q037_2 pq:supportsQuestion q:q037 .

evid:ev_q037_3 a pq:Evidence ;
    pq:evidenceText """A análise de reservatórios no mais simples nível requer uma avaliação da sua porosidade (para calcular o volume de hidrocarbonetos in situ) e sua permeabilidade (para calcular quão facilmente os hidrocarbonetos irão fluir fora dele).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q037_2 .
q:q037 pq:hasEvidence evid:ev_q037_3 .
evid:ev_q037_3 pq:supportsQuestion q:q037 .


