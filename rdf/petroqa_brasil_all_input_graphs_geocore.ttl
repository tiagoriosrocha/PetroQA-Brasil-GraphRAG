evid:ev_q029_1 a pq:Evidence ;
    pq:evidenceText """Essa espessa camada de sal, formada principalmente de halita (cloreto de sódio, ou seja, o sal que usamos na comida) e anidrita (sulfato de cálcio) é uma barreira que se formou diretamente sobre a rocha geradora, impedindo que, neste caso, o petróleo migrasse.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q029_1 .
q:q029 pq:hasEvidence evid:ev_q029_1 .
evid:ev_q029_1 pq:supportsQuestion q:q029 .

evid:ev_q029_2 a pq:Evidence ;
    pq:evidenceText """Seu precipitado gera depósitos de cloretos, sulfatos, boratos e carbonatos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Evaporito | Wikipédia""" ;
    pq:fromSource src:s_q029_2 .
q:q029 pq:hasEvidence evid:ev_q029_2 .
evid:ev_q029_2 pq:supportsQuestion q:q029 .


