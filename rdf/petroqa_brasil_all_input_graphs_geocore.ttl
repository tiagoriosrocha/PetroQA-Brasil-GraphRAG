evid:ev_q007_1 a pq:Evidence ;
    pq:evidenceText """O pré-sal são rochas sedimentares que foram formadas há mais de 100 milhões de anos com a separação dos atuais continentes sul-americano e africano.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q007_1 .
q:q007 pq:hasEvidence evid:ev_q007_1 .
evid:ev_q007_1 pq:supportsQuestion q:q007 .

evid:ev_q007_2 a pq:Evidence ;
    pq:evidenceText """Com essa separação, surgiram grandes depressões que deram origem a diversos lagos, que mais tarde foram conectados aos oceanos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q007_2 .
q:q007 pq:hasEvidence evid:ev_q007_2 .
evid:ev_q007_2 pq:supportsQuestion q:q007 .

evid:ev_q007_3 a pq:Evidence ;
    pq:evidenceText """Formada há mais de 130 milhões de anos, após o início da separação de América do Sul e África, a Bacia de Santos é uma típica bacia sedimentar de margem atlântica, apresentando, porém, uma evolução geológica diferente das bacias de Campos e Pelotas, localizadas respectivamente a norte e sul.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Quem Somos | Comunica Bacia de Santos | Petrobras""" ;
    pq:fromSource src:s_q007_2 .
q:q007 pq:hasEvidence evid:ev_q007_3 .
evid:ev_q007_3 pq:supportsQuestion q:q007 .


