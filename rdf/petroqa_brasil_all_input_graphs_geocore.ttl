evid:ev_q076_1 a pq:Evidence ;
    pq:evidenceText """Turbiditos são depósitos sedimentares originados por correntes de turbidez submarinas, sobretudo em bacias de antepaís (foreland), em ambiente tectônico de margem convergente (ativa).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Turbidito | Wikipédia""" ;
    pq:fromSource src:s_q076_1 .
q:q076 pq:hasEvidence evid:ev_q076_1 .
evid:ev_q076_1 pq:supportsQuestion q:q076 .

evid:ev_q076_2 a pq:Evidence ;
    pq:evidenceText """Os depósitos se formam por fluxos hiperpicnais concentrados, constituindo sucessões de estratos sedimentares arenosos e pelágicos bastante espessos, num curto período de tempo geológico.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Turbidito | Wikipédia""" ;
    pq:fromSource src:s_q076_2 .
q:q076 pq:hasEvidence evid:ev_q076_2 .
evid:ev_q076_2 pq:supportsQuestion q:q076 .

evid:ev_q076_3 a pq:Evidence ;
    pq:evidenceText """As sequências turbidíticas são muito procuradas pelos geólogos de petróleo por constituírem bons reservatórios para hidrocarbonetos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Turbidito | Wikipédia""" ;
    pq:fromSource src:s_q076_2 .
q:q076 pq:hasEvidence evid:ev_q076_3 .
evid:ev_q076_3 pq:supportsQuestion q:q076 .

evid:ev_q076_4 a pq:Evidence ;
    pq:evidenceText """O reservatório é uma unidade litológica porosa e permeável ou conjunto de unidade que retém as reservas de hidrocarbonetos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q076_2 .
q:q076 pq:hasEvidence evid:ev_q076_4 .
evid:ev_q076_4 pq:supportsQuestion q:q076 .


