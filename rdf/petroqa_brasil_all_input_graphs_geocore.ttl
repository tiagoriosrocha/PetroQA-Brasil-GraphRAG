evid:ev_q019_1 pq:supportsQuestion q:q019 .

evid:ev_q019_2 a pq:Evidence ;
    pq:evidenceText """Sistema petrolífero é um modelo que engloba todos os elementos e processos geológicos necessários à existência de acumulações de óleo e gás.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q019_2 .
q:q019 pq:hasEvidence evid:ev_q019_2 .
evid:ev_q019_2 pq:supportsQuestion q:q019 .

evid:ev_q019_3 a pq:Evidence ;
    pq:evidenceText """Para que estas acumulações ocorram, necessita-se de rochas geradoras maduras, rocha reservatório, rocha selante e a sobrecarga.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q019_2 .
q:q019 pq:hasEvidence evid:ev_q019_3 .
evid:ev_q019_3 pq:supportsQuestion q:q019 .

evid:ev_q019_4 a pq:Evidence ;
    pq:evidenceText """Além da presença destas rochas, dois processos geológicos são fundamentais: a formação de trapas e a geração, migração e acumulação de hidrocarbonetos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q019_2 .
