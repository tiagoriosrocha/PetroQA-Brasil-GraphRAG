evid:ev_q116_1 a pq:Evidence ;
    pq:evidenceText """O ambiente de deposição consiste principalmente de lagos, deltas e bacias oceânicas.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q116_1 .
q:q116 pq:hasEvidence evid:ev_q116_1 .
evid:ev_q116_1 pq:supportsQuestion q:q116 .

evid:ev_q116_2 a pq:Evidence ;
    pq:evidenceText """O tipo de petróleo gerado depende do tipo de matéria orgânica: vegetais terrestres carreados tendem a gerar gás, enquanto que os plânctons tendem a gerar óleo.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q116_2 .
q:q116 pq:hasEvidence evid:ev_q116_2 .
evid:ev_q116_2 pq:supportsQuestion q:q116 .

evid:ev_q116_3 a pq:Evidence ;
    pq:evidenceText """Ele forma-se em uma rocha, chamada rocha geradora a partir de restos orgânicos, sobretudo micro-organismos animais.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q116_2 .
q:q116 pq:hasEvidence evid:ev_q116_3 .
evid:ev_q116_3 pq:supportsQuestion q:q116 .

evid:ev_q116_4 a pq:Evidence ;
    pq:evidenceText """Durante milhões de anos esses detritos orgânicos sofrem transformações, que levam a um aumento da temperatura e da pressão interna, o que acaba rompendo a rocha.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q116_2 .
q:q116 pq:hasEvidence evid:ev_q116_4 .
evid:ev_q116_4 pq:supportsQuestion q:q116 .
