src:s_q025_1 a pq:Source ;
    pq:sourceURL """https://petrobras.com.br/pre-sal""" ;
    pq:sourceIndex "1"^^xsd:integer .

src:s_q025_2 a pq:Source ;
    pq:sourceURL """https://pt.wikipedia.org/wiki/Evaporito""" ;
    pq:sourceIndex "2"^^xsd:integer .

evid:ev_q025_1 a pq:Evidence ;
    pq:evidenceText """Por causa do clima árido daquele tempo, a evaporação intensa da água marinha provocou a acumulação de sais, o que criou a camada do pré-sal, uma espécie de proteção que impedia que o petróleo 'escapasse' e chegasse à superfície.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q025_1 .
q:q025 pq:hasEvidence evid:ev_q025_1 .
evid:ev_q025_1 pq:supportsQuestion q:q025 .

evid:ev_q025_2 a pq:Evidence ;
    pq:evidenceText """Na visão tradicional, evaporito ou depósito salino é uma rocha sedimentar formada pela cristalização e precipitação química dos sais dissolvidos em um meio aquoso, devido a um processo de evaporação.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Evaporito | Wikipédia""" ;
    pq:fromSource src:s_q025_2 .
q:q025 pq:hasEvidence evid:ev_q025_2 .
evid:ev_q025_2 pq:supportsQuestion q:q025 .

evid:ev_q025_3 a pq:Evidence ;
    pq:evidenceText """Seu ambiente de formação são bacias fechadas sujeitas a evaporação intensa.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Evaporito | Wikipédia""" ;
    pq:fromSource src:s_q025_2 .
q:q025 pq:hasEvidence evid:ev_q025_3 .
evid:ev_q025_3 pq:supportsQuestion q:q025 .
