evid:ev_q003_1 pq:supportsQuestion q:q003 .

evid:ev_q003_2 a pq:Evidence ;
    pq:evidenceText """Esta matéria orgânica, misturada a sedimentos, formou o que são as rochas que geram o óleo e o gás do pré-sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q003_2 .
q:q003 pq:hasEvidence evid:ev_q003_2 .
evid:ev_q003_2 pq:supportsQuestion q:q003 .

evid:ev_q003_3 a pq:Evidence ;
    pq:evidenceText """A rocha onde o petróleo se forma é chamada de rocha geradora.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo | SGB""" ;
    pq:fromSource src:s_q003_2 .
q:q003 pq:hasEvidence evid:ev_q003_3 .
evid:ev_q003_3 pq:supportsQuestion q:q003 .

evid:ev_q003_4 a pq:Evidence ;
    pq:evidenceText """As rochas geradoras mais comuns são folhelhos negros.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo | SGB""" ;
    pq:fromSource src:s_q003_2 .
