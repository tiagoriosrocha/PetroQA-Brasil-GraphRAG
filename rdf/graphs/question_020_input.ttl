evid:ev_q020_1 a pq:Evidence ;
    pq:evidenceText """Com isso, o petróleo migra para cima através dos poros existentes nas rochas, até encontrar algo que o impeça de continuar se deslocando.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q020_1 .
q:q020 pq:hasEvidence evid:ev_q020_1 .
evid:ev_q020_1 pq:supportsQuestion q:q020 .

evid:ev_q020_2 a pq:Evidence ;
    pq:evidenceText """Essa espessa camada de sal, formada principalmente de halita (cloreto de sódio, ou seja, o sal que usamos na comida) e anidrita (sulfato de cálcio) é uma barreira que se formou diretamente sobre a rocha geradora, impedindo que, neste caso, o petróleo migrasse.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q020_2 .
q:q020 pq:hasEvidence evid:ev_q020_2 .
evid:ev_q020_2 pq:supportsQuestion q:q020 .

evid:ev_q020_3 a pq:Evidence ;
    pq:evidenceText """Por causa do clima árido daquele tempo, a evaporação intensa da água marinha provocou a acumulação de sais, o que criou a camada do pré-sal, uma espécie de proteção que impedia que o petróleo 'escapasse' e chegasse à superfície.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q020_2 .
q:q020 pq:hasEvidence evid:ev_q020_3 .
evid:ev_q020_3 pq:supportsQuestion q:q020 .
