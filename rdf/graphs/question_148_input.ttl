evid:ev_q148_2 a pq:Evidence ;
    pq:evidenceText """Essa barreira, chamada de trapa, pode ser uma rocha impermeável, como uma camada de sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q148_2 .
q:q148 pq:hasEvidence evid:ev_q148_2 .
evid:ev_q148_2 pq:supportsQuestion q:q148 .

evid:ev_q148_3 a pq:Evidence ;
    pq:evidenceText """Essa espessa camada de sal, formada principalmente de halita (cloreto de sódio, ou seja, o sal que usamos na comida) e anidrita (sulfato de cálcio) é uma barreira que se formou diretamente sobre a rocha geradora, impedindo que, neste caso, o petróleo migrasse.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q148_2 .
q:q148 pq:hasEvidence evid:ev_q148_3 .
evid:ev_q148_3 pq:supportsQuestion q:q148 .
