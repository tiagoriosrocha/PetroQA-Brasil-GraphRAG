evid:ev_q060_1 a pq:Evidence ;
    pq:evidenceText """Os reservatórios são rochas carbonáticas de origem lacustre (idade aptiana), depositadas durante o rifteamento oblíquo de abertura da Bacia de Santos e compreende às formações Itapema (Sequência K38) e Barra Velha (Sequências K44 e K46/K48).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Búzios: a jornada desde a caracterização dos reservatórios ao início do desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q060_1 .
q:q060 pq:hasEvidence evid:ev_q060_1 .
evid:ev_q060_1 pq:supportsQuestion q:q060 .

evid:ev_q060_2 a pq:Evidence ;
    pq:evidenceText """Formada há mais de 130 milhões de anos, após o início da separação de América do Sul e África, a Bacia de Santos é uma típica bacia sedimentar de margem atlântica, apresentando, porém, uma evolução geológica diferente das bacias de Campos e Pelotas, localizadas respectivamente a norte e sul.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Quem Somos | Comunica Bacia de Santos | Petrobras""" ;
    pq:fromSource src:s_q060_2 .
q:q060 pq:hasEvidence evid:ev_q060_2 .
evid:ev_q060_2 pq:supportsQuestion q:q060 .
