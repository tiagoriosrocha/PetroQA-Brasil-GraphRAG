evid:ev_q108_1 a pq:Evidence ;
    pq:evidenceText """A condição para o armazenamento do petróleo nas rochas reservatório é a porosidade de tais rochas, que variam de 5% a 35%, tendo em média de 15% a 30%.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q108_1 .
q:q108 pq:hasEvidence evid:ev_q108_1 .
evid:ev_q108_1 pq:supportsQuestion q:q108 .

evid:ev_q108_2 a pq:Evidence ;
    pq:evidenceText """Geralmente são compostas por granulometria de areia a seixo como arenitos, calcarenitos ou conglomerados.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q108_2 .
q:q108 pq:hasEvidence evid:ev_q108_2 .
evid:ev_q108_2 pq:supportsQuestion q:q108 .

evid:ev_q108_3 a pq:Evidence ;
    pq:evidenceText """Cascalhos formam conglomerados e brechas, areias formam arenitos, siltes formam siltitos e argilas formam argilitos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Rochas | SGB""" ;
    pq:fromSource src:s_q108_2 .
q:q108 pq:hasEvidence evid:ev_q108_3 .
evid:ev_q108_3 pq:supportsQuestion q:q108 .
