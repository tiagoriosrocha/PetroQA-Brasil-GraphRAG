evid:ev_q100_1 a pq:Evidence ;
    pq:evidenceText """Com isso, o petróleo migra para cima através dos poros existentes nas rochas, até encontrar algo que o impeça de continuar se deslocando.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q100_1 .
q:q100 pq:hasEvidence evid:ev_q100_1 .
evid:ev_q100_1 pq:supportsQuestion q:q100 .

evid:ev_q100_2 a pq:Evidence ;
    pq:evidenceText """Essa barreira, chamada de trapa, pode ser uma rocha impermeável, como uma camada de sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q100_2 .
q:q100 pq:hasEvidence evid:ev_q100_2 .
evid:ev_q100_2 pq:supportsQuestion q:q100 .

evid:ev_q100_3 a pq:Evidence ;
    pq:evidenceText """A 'trapa é a característica estratigráfica ou estrutural, que garante a justaposição do reservatório e selo de tal forma que os hidrocarbonetos permanecem presos no subsolo, em vez de fugir (devido à sua natural flutuabilidade) e se perderem.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q100_2 .
q:q100 pq:hasEvidence evid:ev_q100_3 .
evid:ev_q100_3 pq:supportsQuestion q:q100 .
