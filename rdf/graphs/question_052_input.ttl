evid:ev_q052_1 pq:supportsQuestion q:q052 .

evid:ev_q052_2 a pq:Evidence ;
    pq:evidenceText """À época foram constatados reservatórios carbonáticos, pertencentes às Formações Barra Velha e Itapema, com excelentes qualidades permoporosa e uma coluna de óleo de cerca de 300 m.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Mero: caracterização dos reservatórios e desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q052_2 .
q:q052 pq:hasEvidence evid:ev_q052_2 .
evid:ev_q052_2 pq:supportsQuestion q:q052 .

evid:ev_q052_3 a pq:Evidence ;
    pq:evidenceText """A Bacia de Santos é a maior bacia sedimentar marítima brasileira, com uma área total de mais de 350 mil quilômetros quadrados e que se estende de Cabo Frio (RJ) a Florianópolis (SC).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Quem Somos | Comunica Bacia de Santos | Petrobras""" ;
    pq:fromSource src:s_q052_2 .
q:q052 pq:hasEvidence evid:ev_q052_3 .
evid:ev_q052_3 pq:supportsQuestion q:q052 .
