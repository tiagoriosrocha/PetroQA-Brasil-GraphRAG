evid:ev_q122_1 a pq:Evidence ;
    pq:evidenceText """As rochas sedimentares formam-se pela deposição de sedimentos (cascalho, areia, argila etc.) ao longo do tempo, trazidos por agentes transportadores, como as águas de um rio, o vento e as geleiras.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Como Sabemos a Idade das Rochas? | SGB""" ;
    pq:fromSource src:s_q122_1 .
q:q122 pq:hasEvidence evid:ev_q122_1 .
evid:ev_q122_1 pq:supportsQuestion q:q122 .

evid:ev_q122_2 a pq:Evidence ;
    pq:evidenceText """Esse material vai sendo empilhado e, naturalmente, quanto mais embaixo ele estiver na pilha mais antigo ele é.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Como Sabemos a Idade das Rochas? | SGB""" ;
    pq:fromSource src:s_q122_2 .
q:q122 pq:hasEvidence evid:ev_q122_2 .
evid:ev_q122_2 pq:supportsQuestion q:q122 .

evid:ev_q122_3 a pq:Evidence ;
    pq:evidenceText """Rochas sedimentares detríticas (também chamadas de clásticas) são aquelas formadas pela deposição de fragmentos de outras rochas (ígneas, metamórficas ou mesmo sedimentares).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Rochas | SGB""" ;
    pq:fromSource src:s_q122_2 .
q:q122 pq:hasEvidence evid:ev_q122_3 .
evid:ev_q122_3 pq:supportsQuestion q:q122 .
