evid:ev_q115_1 a pq:Evidence ;
    pq:evidenceText """A análise de reservatórios no mais simples nível requer uma avaliação da sua porosidade (para calcular o volume de hidrocarbonetos in situ) e sua permeabilidade (para calcular quão facilmente os hidrocarbonetos irão fluir fora dele).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q115_1 .
q:q115 pq:hasEvidence evid:ev_q115_1 .
evid:ev_q115_1 pq:supportsQuestion q:q115 .

evid:ev_q115_2 a pq:Evidence ;
    pq:evidenceText """Possuem porosidade e permeabilidade, uma marcante estratificação e baixa resistência mecânica.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Rochas | SGB""" ;
    pq:fromSource src:s_q115_2 .
q:q115 pq:hasEvidence evid:ev_q115_2 .
