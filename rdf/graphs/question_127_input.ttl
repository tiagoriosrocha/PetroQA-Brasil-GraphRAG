evid:ev_q127_2 a pq:Evidence ;
    pq:evidenceText """Seu limite, ao sul, com a Bacia de Santos ocorre no Alto de Cabo Frio; ao norte, com a Bacia do Espírito Santo, ocorre no Alto de Vitória.""" ;
