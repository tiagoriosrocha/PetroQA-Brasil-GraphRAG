evid:ev_q141_1 a pq:Evidence ;
    pq:evidenceText """O petróleo e gás natural são encontrados tanto em terra quanto no mar, principalmente nas bacias sedimentares (onde se encontram meios mais porosos - reservatórios), mas também em rochas do embasamento cristalino.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo | Wikipédia""" ;
    pq:fromSource src:s_q141_1 .
q:q141 pq:hasEvidence evid:ev_q141_1 .
evid:ev_q141_1 pq:supportsQuestion q:q141 .

evid:ev_q141_2 a pq:Evidence ;
    pq:evidenceText """Os hidrocarbonetos, portanto, ocupam espaços porosos nas rochas, sejam eles entre grãos ou fraturas.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo | Wikipédia""" ;
    pq:fromSource src:s_q141_2 .
q:q141 pq:hasEvidence evid:ev_q141_2 .
evid:ev_q141_2 pq:supportsQuestion q:q141 .

evid:ev_q141_3 a pq:Evidence ;
    pq:evidenceText """A condição para o armazenamento do petróleo nas rochas reservatório é a porosidade de tais rochas, que variam de 5% a 35%, tendo em média de 15% a 30%.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q141_2 .
q:q141 pq:hasEvidence evid:ev_q141_3 .
evid:ev_q141_3 pq:supportsQuestion q:q141 .
