evid:ev_q111_1 a pq:Evidence ;
    pq:evidenceText """Sistema petrolífero é um modelo que engloba todos os elementos e processos geológicos necessários à existência de acumulações de óleo e gás.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q111_1 .
q:q111 pq:hasEvidence evid:ev_q111_1 .
evid:ev_q111_1 pq:supportsQuestion q:q111 .

evid:ev_q111_2 a pq:Evidence ;
    pq:evidenceText """Para que estas acumulações ocorram, necessita-se de rochas geradoras maduras, rocha reservatório, rocha selante e a sobrecarga.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q111_2 .
q:q111 pq:hasEvidence evid:ev_q111_2 .
evid:ev_q111_2 pq:supportsQuestion q:q111 .

evid:ev_q111_3 a pq:Evidence ;
    pq:evidenceText """Além da presença destas rochas, dois processos geológicos são fundamentais: a formação de trapas e a geração, migração e acumulação de hidrocarbonetos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q111_2 .
q:q111 pq:hasEvidence evid:ev_q111_3 .
evid:ev_q111_3 pq:supportsQuestion q:q111 .

evid:ev_q111_4 a pq:Evidence ;
    pq:evidenceText """Todas estas condições devem ocorrer de forma sincronizada em relação ao tempo geológico.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q111_2 .
q:q111 pq:hasEvidence evid:ev_q111_4 .
evid:ev_q111_4 pq:supportsQuestion q:q111 .

evid:ev_q111_5 a pq:Evidence ;
    pq:evidenceText """A rocha onde o petróleo se forma é chamada de rocha geradora.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo | SGB""" ;
    pq:fromSource src:s_q111_2 .
q:q111 pq:hasEvidence evid:ev_q111_5 .
evid:ev_q111_5 pq:supportsQuestion q:q111 .

evid:ev_q111_6 a pq:Evidence ;
    pq:evidenceText """Dela, ele migra para cima até ficar aprisionado na rocha reservatório (se não chegar até à superfície), de onde é extraído.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo | SGB""" ;
    pq:fromSource src:s_q111_2 .
q:q111 pq:hasEvidence evid:ev_q111_6 .
evid:ev_q111_6 pq:supportsQuestion q:q111 .

evid:ev_q111_7 a pq:Evidence ;
    pq:evidenceText """Folhelhos e camadas de sal são rochas capeadoras comuns.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo | SGB""" ;
    pq:fromSource src:s_q111_2 .
q:q111 pq:hasEvidence evid:ev_q111_7 .
evid:ev_q111_7 pq:supportsQuestion q:q111 .
