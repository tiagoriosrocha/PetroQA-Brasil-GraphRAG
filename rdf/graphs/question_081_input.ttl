    pq:sourceURL """https://pt.wikipedia.org/wiki/Turbidito""" ;
    pq:sourceIndex "2"^^xsd:integer .

evid:ev_q081_1 a pq:Evidence ;
    pq:evidenceText """A Petrobras descobriu uma acumulação de petróleo em águas ultraprofundas da Bacia Potiguar, no poço exploratório Anhangá, da Concessão POT-M-762_R15.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petrobras descobre petróleo em águas ultraprofundas da Bacia Potiguar | Agência Petrobras""" ;
    pq:fromSource src:s_q081_1 .
q:q081 pq:hasEvidence evid:ev_q081_1 .
evid:ev_q081_1 pq:supportsQuestion q:q081 .

evid:ev_q081_2 a pq:Evidence ;
    pq:evidenceText """A constatação de reservatórios turbidíticos de idade Albiana portador de petróleo é inédita na Bacia Potiguar e foi realizada através de perfis elétricos e amostras de óleo, que serão posteriormente caracterizados por meio de análises de laboratório.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petrobras descobre petróleo em águas ultraprofundas da Bacia Potiguar | Agência Petrobras""" ;
    pq:fromSource src:s_q081_2 .
q:q081 pq:hasEvidence evid:ev_q081_2 .
evid:ev_q081_2 pq:supportsQuestion q:q081 .

evid:ev_q081_3 a pq:Evidence ;
    pq:evidenceText """Turbiditos são depósitos sedimentares originados por correntes de turbidez submarinas, sobretudo em bacias de antepaís (foreland), em ambiente tectônico de margem convergente (ativa).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Turbidito | Wikipédia""" ;
    pq:fromSource src:s_q081_2 .
q:q081 pq:hasEvidence evid:ev_q081_3 .
evid:ev_q081_3 pq:supportsQuestion q:q081 .
