    pq:sourceIndex "2"^^xsd:integer .

evid:ev_q024_1 a pq:Evidence ;
    pq:evidenceText """Tal conjunto de rochas, com potencial para a formação de petróleo, está localizado sob uma extensa camada de sal que atinge espessuras de até 2 mil metros, formando uma espécie de selo e garantindo, assim, a geração de óleo de ótima qualidade.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal Bacia de Santos | Comunica Bacia de Santos | Petrobras""" ;
    pq:fromSource src:s_q024_1 .
q:q024 pq:hasEvidence evid:ev_q024_1 .
evid:ev_q024_1 pq:supportsQuestion q:q024 .

evid:ev_q024_2 a pq:Evidence ;
    pq:evidenceText """O selo, ou rocha selante, é uma unidade com baixa permeabilidade que impede o escape de hidrocarbonetos da rocha reservatório.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q024_2 .
q:q024 pq:hasEvidence evid:ev_q024_2 .
evid:ev_q024_2 pq:supportsQuestion q:q024 .

evid:ev_q024_3 a pq:Evidence ;
    pq:evidenceText """A 'trapa é a característica estratigráfica ou estrutural, que garante a justaposição do reservatório e selo de tal forma que os hidrocarbonetos permanecem presos no subsolo, em vez de fugir (devido à sua natural flutuabilidade) e se perderem.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q024_2 .
q:q024 pq:hasEvidence evid:ev_q024_3 .
evid:ev_q024_3 pq:supportsQuestion q:q024 .
