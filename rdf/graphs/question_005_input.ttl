evid:ev_q005_1 a pq:Evidence ;
    pq:evidenceText """Nas partes mais rasas destes lagos, em grandes ilhas lacustres, surgiram as chamadas conchas calcárias que se acumularam cada vez mais com o passar do tempo.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q005_1 .
q:q005 pq:hasEvidence evid:ev_q005_1 .
evid:ev_q005_1 pq:supportsQuestion q:q005 .

evid:ev_q005_2 a pq:Evidence ;
    pq:evidenceText """Mais pra frente, essas conchas 'ganharam a companhia' de depósitos de estromatólitos, que nada mais são do que tipos de algas que formam rochas calcárias.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q005_2 .
q:q005 pq:hasEvidence evid:ev_q005_2 .
evid:ev_q005_2 pq:supportsQuestion q:q005 .

evid:ev_q005_3 a pq:Evidence ;
    pq:evidenceText """Tanto as conchas calcárias quanto as rochas calcárias compõem os principais reservatórios do pré-sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q005_2 .
q:q005 pq:hasEvidence evid:ev_q005_3 .
evid:ev_q005_3 pq:supportsQuestion q:q005 .

evid:ev_q005_4 a pq:Evidence ;
    pq:evidenceText """A condição para o armazenamento do petróleo nas rochas reservatório é a porosidade de tais rochas, que variam de 5% a 35%, tendo em média de 15% a 30%.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q005_2 .
q:q005 pq:hasEvidence evid:ev_q005_4 .
evid:ev_q005_4 pq:supportsQuestion q:q005 .

evid:ev_q005_5 a pq:Evidence ;
    pq:evidenceText """Geralmente são compostas por granulometria de areia a seixo como arenitos, calcarenitos ou conglomerados.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q005_2 .
q:q005 pq:hasEvidence evid:ev_q005_5 .
evid:ev_q005_5 pq:supportsQuestion q:q005 .
