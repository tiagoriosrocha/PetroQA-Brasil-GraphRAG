evid:ev_q099_2 a pq:Evidence ;
    pq:evidenceText """Dela, ele migra para cima até ficar aprisionado na rocha reservatório (se não chegar até à superfície), de onde é extraído.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo | SGB""" ;
    pq:fromSource src:s_q099_2 .
q:q099 pq:hasEvidence evid:ev_q099_2 .
evid:ev_q099_2 pq:supportsQuestion q:q099 .

evid:ev_q099_3 a pq:Evidence ;
    pq:evidenceText """Os caminhos de migração constituem-se das fraturas, falhas, rochas carreadoras (rochas com porosidade e permeabilidade suficientes para permitir o transporte).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q099_2 .
q:q099 pq:hasEvidence evid:ev_q099_3 .
evid:ev_q099_3 pq:supportsQuestion q:q099 .

evid:ev_q099_4 a pq:Evidence ;
    pq:evidenceText """O petróleo gerado percorre estes caminhos até encontrar uma trapa.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q099_2 .
