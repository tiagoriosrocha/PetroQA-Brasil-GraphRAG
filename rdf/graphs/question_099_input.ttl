    pq:evidenceText """A rocha onde o petróleo se forma é chamada de rocha geradora.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo | SGB""" ;
    pq:fromSource src:s_q099_1 .
