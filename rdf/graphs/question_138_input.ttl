evid:ev_q138_1 a pq:Evidence ;
    pq:evidenceText """Formada há mais de 130 milhões de anos, após o início da separação de América do Sul e África, a Bacia de Santos é uma típica bacia sedimentar de margem atlântica, apresentando, porém, uma evolução geológica diferente das bacias de Campos e Pelotas, localizadas respectivamente a norte e sul.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Quem Somos | Comunica Bacia de Santos | Petrobras""" ;
    pq:fromSource src:s_q138_1 .
q:q138 pq:hasEvidence evid:ev_q138_1 .
evid:ev_q138_1 pq:supportsQuestion q:q138 .

evid:ev_q138_2 a pq:Evidence ;
    pq:evidenceText """Reconhece-se quatro estágios geológicos evolutivos na bacia de Campos, que são pré-rifte (continental), rifte (continental), proto-oceânico (transicional evaporítico) e drift (marinho).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Bacia de Campos | Wikipédia""" ;
    pq:fromSource src:s_q138_2 .
q:q138 pq:hasEvidence evid:ev_q138_2 .
evid:ev_q138_2 pq:supportsQuestion q:q138 .
