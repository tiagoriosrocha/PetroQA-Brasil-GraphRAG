evid:ev_q004_1 a pq:Evidence ;
    pq:evidenceText """Nas partes mais rasas destes lagos, em grandes ilhas lacustres, surgiram as chamadas conchas calcárias que se acumularam cada vez mais com o passar do tempo.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q004_1 .
q:q004 pq:hasEvidence evid:ev_q004_1 .
evid:ev_q004_1 pq:supportsQuestion q:q004 .

evid:ev_q004_2 a pq:Evidence ;
    pq:evidenceText """Mais pra frente, essas conchas 'ganharam a companhia' de depósitos de estromatólitos, que nada mais são do que tipos de algas que formam rochas calcárias.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q004_2 .
q:q004 pq:hasEvidence evid:ev_q004_2 .
evid:ev_q004_2 pq:supportsQuestion q:q004 .

evid:ev_q004_3 a pq:Evidence ;
    pq:evidenceText """Tanto as conchas calcárias quanto as rochas calcárias compõem os principais reservatórios do pré-sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q004_2 .
q:q004 pq:hasEvidence evid:ev_q004_3 .
evid:ev_q004_3 pq:supportsQuestion q:q004 .

evid:ev_q004_4 a pq:Evidence ;
    pq:evidenceText """O reservatório é uma unidade litológica porosa e permeável ou conjunto de unidade que retém as reservas de hidrocarbonetos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q004_2 .
q:q004 pq:hasEvidence evid:ev_q004_4 .
evid:ev_q004_4 pq:supportsQuestion q:q004 .
