evid:ev_q035_1 a pq:Evidence ;
    pq:evidenceText """O pré-sal são rochas sedimentares que foram formadas há mais de 100 milhões de anos com a separação dos atuais continentes sul-americano e africano.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q035_1 .
q:q035 pq:hasEvidence evid:ev_q035_1 .
evid:ev_q035_1 pq:supportsQuestion q:q035 .

evid:ev_q035_2 a pq:Evidence ;
    pq:evidenceText """Com essa separação, surgiram grandes depressões que deram origem a diversos lagos, que mais tarde foram conectados aos oceanos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q035_2 .
q:q035 pq:hasEvidence evid:ev_q035_2 .
evid:ev_q035_2 pq:supportsQuestion q:q035 .

evid:ev_q035_3 a pq:Evidence ;
    pq:evidenceText """Nas regiões mais profundas destes lagos começaram a acumular grandes quantidades de matéria orgânica de algas microscópicas.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q035_2 .
q:q035 pq:hasEvidence evid:ev_q035_3 .
evid:ev_q035_3 pq:supportsQuestion q:q035 .

evid:ev_q035_4 a pq:Evidence ;
    pq:evidenceText """Esta matéria orgânica, misturada a sedimentos, formou o que são as rochas que geram o óleo e o gás do pré-sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q035_2 .
q:q035 pq:hasEvidence evid:ev_q035_4 .
evid:ev_q035_4 pq:supportsQuestion q:q035 .

evid:ev_q035_5 a pq:Evidence ;
    pq:evidenceText """A Geodinâmica é a ciência que investiga a dinâmica da Terra buscando entender todos os processos geológicos envolvidos na sua transformação ao longo do tempo geológico e na geração de recursos naturais como minério, óleo e gás.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia | SGB""" ;
    pq:fromSource src:s_q035_2 .
q:q035 pq:hasEvidence evid:ev_q035_5 .
evid:ev_q035_5 pq:supportsQuestion q:q035 .
