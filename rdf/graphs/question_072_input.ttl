evid:ev_q072_1 a pq:Evidence ;
    pq:evidenceText """A Bacia de Campos é uma bacia sedimentar brasileira situada na costa norte do estado do Rio de Janeiro, estendendo-se até o sul do estado do Espírito Santo, entre os paralelos 21 e 23 sul.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Bacia de Campos | Wikipédia""" ;
    pq:fromSource src:s_q072_1 .
q:q072 pq:hasEvidence evid:ev_q072_1 .
evid:ev_q072_1 pq:supportsQuestion q:q072 .

evid:ev_q072_2 a pq:Evidence ;
    pq:evidenceText """Seu limite, ao sul, com a Bacia de Santos ocorre no Alto de Cabo Frio; ao norte, com a Bacia do Espírito Santo, ocorre no Alto de Vitória.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Bacia de Campos | Wikipédia""" ;
    pq:fromSource src:s_q072_2 .
q:q072 pq:hasEvidence evid:ev_q072_2 .
evid:ev_q072_2 pq:supportsQuestion q:q072 .

evid:ev_q072_3 a pq:Evidence ;
    pq:evidenceText """Formada há mais de 130 milhões de anos, após o início da separação de América do Sul e África, a Bacia de Santos é uma típica bacia sedimentar de margem atlântica, apresentando, porém, uma evolução geológica diferente das bacias de Campos e Pelotas, localizadas respectivamente a norte e sul.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Quem Somos | Comunica Bacia de Santos | Petrobras""" ;
    pq:fromSource src:s_q072_2 .
q:q072 pq:hasEvidence evid:ev_q072_3 .
evid:ev_q072_3 pq:supportsQuestion q:q072 .
