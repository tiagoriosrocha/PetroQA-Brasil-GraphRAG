evid:ev_q095_1 a pq:Evidence ;
    pq:evidenceText """Sistema petrolífero é um modelo que engloba todos os elementos e processos geológicos necessários à existência de acumulações de óleo e gás.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q095_1 .
q:q095 pq:hasEvidence evid:ev_q095_1 .
evid:ev_q095_1 pq:supportsQuestion q:q095 .

evid:ev_q095_2 a pq:Evidence ;
    pq:evidenceText """Para que estas acumulações ocorram, necessita-se de rochas geradoras maduras, rocha reservatório, rocha selante e a sobrecarga.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q095_2 .
q:q095 pq:hasEvidence evid:ev_q095_2 .
evid:ev_q095_2 pq:supportsQuestion q:q095 .

evid:ev_q095_3 a pq:Evidence ;
    pq:evidenceText """Além da presença destas rochas, dois processos geológicos são fundamentais: a formação de trapas e a geração, migração e acumulação de hidrocarbonetos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q095_2 .
q:q095 pq:hasEvidence evid:ev_q095_3 .
evid:ev_q095_3 pq:supportsQuestion q:q095 .

evid:ev_q095_4 a pq:Evidence ;
    pq:evidenceText """As rochas geradoras de hidrocarbonetos da Bacia de Campos correspondem a folhelhos orgânicos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Bacia de Campos | Wikipédia""" ;
    pq:fromSource src:s_q095_2 .
q:q095 pq:hasEvidence evid:ev_q095_4 .
evid:ev_q095_4 pq:supportsQuestion q:q095 .

evid:ev_q095_5 a pq:Evidence ;
    pq:evidenceText """As principais rochas reservatório da bacia são arenitos turbidíticos, depositados desde o andar geológico Albiano até o Mioceno, seguidos de calcarenitos, depositados durante o andar Albiano, calcáreos de origem microbial, principalmente cianobactérias, depositadas durante o andar Aptiano e de coquinas, rochas formadas por restos de carapaças de crustáceos, e que foram depositadas durante o andar Barremiano.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Bacia de Campos | Wikipédia""" ;
    pq:fromSource src:s_q095_2 .
q:q095 pq:hasEvidence evid:ev_q095_5 .
evid:ev_q095_5 pq:supportsQuestion q:q095 .
