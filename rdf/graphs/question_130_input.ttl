evid:ev_q130_1 pq:supportsQuestion q:q130 .

evid:ev_q130_2 a pq:Evidence ;
    pq:evidenceText """Em 1974 a Petrobrás descobre indícios de petróleo na Bacia de Campos, confirmados com a perfuração do primeiro poço em 1976.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo | Wikipédia""" ;
    pq:fromSource src:s_q130_2 .
