evid:ev_q106_1 a pq:Evidence ;
    pq:evidenceText """Rochas sedimentares detríticas (também chamadas de clásticas) são aquelas formadas pela deposição de fragmentos de outras rochas (ígneas, metamórficas ou mesmo sedimentares).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Rochas | SGB""" ;
    pq:fromSource src:s_q106_1 .
q:q106 pq:hasEvidence evid:ev_q106_1 .
evid:ev_q106_1 pq:supportsQuestion q:q106 .

evid:ev_q106_2 a pq:Evidence ;
    pq:evidenceText """Conforme o diâmetro dos grãos desses sedimentos, eles podem ser, do maior para o menor: cascalho, areia, silte ou argila (conforme tabela a seguir).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Rochas | SGB""" ;
    pq:fromSource src:s_q106_2 .
q:q106 pq:hasEvidence evid:ev_q106_2 .
evid:ev_q106_2 pq:supportsQuestion q:q106 .

evid:ev_q106_3 a pq:Evidence ;
    pq:evidenceText """Cascalhos formam conglomerados e brechas, areias formam arenitos, siltes formam siltitos e argilas formam argilitos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Rochas | SGB""" ;
    pq:fromSource src:s_q106_2 .
q:q106 pq:hasEvidence evid:ev_q106_3 .
evid:ev_q106_3 pq:supportsQuestion q:q106 .

evid:ev_q106_4 a pq:Evidence ;
    pq:evidenceText """Geralmente são compostas por granulometria de areia a seixo como arenitos, calcarenitos ou conglomerados.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q106_2 .
q:q106 pq:hasEvidence evid:ev_q106_4 .
evid:ev_q106_4 pq:supportsQuestion q:q106 .
