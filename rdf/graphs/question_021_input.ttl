    pq:sourceIndex "2"^^xsd:integer .

evid:ev_q021_1 a pq:Evidence ;
    pq:evidenceText """Depósitos bioclásticos de moluscos bivalves do Barremiano/Aptiano, denominados coquinas do andar local Jiquiá, ocorrem sobre blocos altos falhados, formados durante a tectônica rifte, em morfologias herdadas do embasamento, intercalados com fácies ricas em matéria orgânica em camadas conformantes contínuas nos baixos adjacentes, em ambiente de água doce a salobra.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Estratigrafia e modelos deposicionais carbonáticos do Pré-sal da Bacia de Santos | Universidade Petrobras""" ;
    pq:fromSource src:s_q021_1 .
q:q021 pq:hasEvidence evid:ev_q021_1 .
evid:ev_q021_1 pq:supportsQuestion q:q021 .

evid:ev_q021_2 a pq:Evidence ;
    pq:evidenceText """Para que estas acumulações ocorram, necessita-se de rochas geradoras maduras, rocha reservatório, rocha selante e a sobrecarga.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q021_2 .
q:q021 pq:hasEvidence evid:ev_q021_2 .
evid:ev_q021_2 pq:supportsQuestion q:q021 .

evid:ev_q021_3 a pq:Evidence ;
    pq:evidenceText """Além da presença destas rochas, dois processos geológicos são fundamentais: a formação de trapas e a geração, migração e acumulação de hidrocarbonetos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q021_2 .
q:q021 pq:hasEvidence evid:ev_q021_3 .
evid:ev_q021_3 pq:supportsQuestion q:q021 .
