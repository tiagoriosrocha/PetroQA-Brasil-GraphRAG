evid:ev_q128_1 a pq:Evidence ;
    pq:evidenceText """A maior parte da margem continental brasileira é uma clássica margem divergente formada pela ruptura do supercontinente Gondwana e o distanciamento das placas Sul-Americana e Africana.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Plataforma continental do Brasil | Wikipédia""" ;
    pq:fromSource src:s_q128_1 .
