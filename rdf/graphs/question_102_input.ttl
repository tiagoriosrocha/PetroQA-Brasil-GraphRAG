evid:ev_q102_1 a pq:Evidence ;
    pq:evidenceText """O reservatório é uma unidade litológica porosa e permeável ou conjunto de unidade que retém as reservas de hidrocarbonetos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q102_1 .
q:q102 pq:hasEvidence evid:ev_q102_1 .
evid:ev_q102_1 pq:supportsQuestion q:q102 .

evid:ev_q102_2 a pq:Evidence ;
    pq:evidenceText """O selo, ou rocha selante, é uma unidade com baixa permeabilidade que impede o escape de hidrocarbonetos da rocha reservatório.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q102_2 .
q:q102 pq:hasEvidence evid:ev_q102_2 .
evid:ev_q102_2 pq:supportsQuestion q:q102 .

evid:ev_q102_3 a pq:Evidence ;
    pq:evidenceText """A condição para o armazenamento do petróleo nas rochas reservatório é a porosidade de tais rochas, que variam de 5% a 35%, tendo em média de 15% a 30%.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q102_2 .
q:q102 pq:hasEvidence evid:ev_q102_3 .
evid:ev_q102_3 pq:supportsQuestion q:q102 .

evid:ev_q102_4 a pq:Evidence ;
    pq:evidenceText """As rochas selantes são rochas de baixa permeabilidade, como folhelhos, siltitos e calciculitos, de forma que impedem o escape dos fluidos da rocha reservatório.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q102_2 .
q:q102 pq:hasEvidence evid:ev_q102_4 .
evid:ev_q102_4 pq:supportsQuestion q:q102 .
