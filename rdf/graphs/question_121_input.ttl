    pq:sourceIndex "2"^^xsd:integer .

evid:ev_q121_1 a pq:Evidence ;
    pq:evidenceText """As rochas sedimentares formam-se pela deposição de sedimentos (cascalho, areia, argila etc.) ao longo do tempo, trazidos por agentes transportadores, como as águas de um rio, o vento e as geleiras.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Como Sabemos a Idade das Rochas? | SGB""" ;
    pq:fromSource src:s_q121_1 .
q:q121 pq:hasEvidence evid:ev_q121_1 .
evid:ev_q121_1 pq:supportsQuestion q:q121 .

evid:ev_q121_2 a pq:Evidence ;
    pq:evidenceText """Esse material vai sendo empilhado e, naturalmente, quanto mais embaixo ele estiver na pilha mais antigo ele é.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Como Sabemos a Idade das Rochas? | SGB""" ;
    pq:fromSource src:s_q121_2 .
q:q121 pq:hasEvidence evid:ev_q121_2 .
evid:ev_q121_2 pq:supportsQuestion q:q121 .

evid:ev_q121_3 a pq:Evidence ;
    pq:evidenceText """O prefixo pré-, portanto, refere-se ao tempo, não ao espaço.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo do Pré-Sal | SGB""" ;
    pq:fromSource src:s_q121_2 .
q:q121 pq:hasEvidence evid:ev_q121_3 .
evid:ev_q121_3 pq:supportsQuestion q:q121 .
