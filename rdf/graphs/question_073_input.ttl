evid:ev_q073_1 a pq:Evidence ;
    pq:evidenceText """Seu limite, ao sul, com a Bacia de Santos ocorre no Alto de Cabo Frio; ao norte, com a Bacia do Espírito Santo, ocorre no Alto de Vitória.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Bacia de Campos | Wikipédia""" ;
    pq:fromSource src:s_q073_1 .
q:q073 pq:hasEvidence evid:ev_q073_1 .
evid:ev_q073_1 pq:supportsQuestion q:q073 .

evid:ev_q073_2 a pq:Evidence ;
    pq:evidenceText """O pré-sal é uma formação rochosa localizada no subsolo da costa brasileira, que se estende entre os estados de Santa Catarina e Espírito Santo, atingindo uma área de cerca de 800 quilômetros de extensão por 200 quilômetros de largura.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal Bacia de Santos | Comunica Bacia de Santos | Petrobras""" ;
    pq:fromSource src:s_q073_2 .
q:q073 pq:hasEvidence evid:ev_q073_2 .
evid:ev_q073_2 pq:supportsQuestion q:q073 .
