evid:ev_q109_2 a pq:Evidence ;
    pq:evidenceText """Geralmente estas rochas situam-se acima do reservatório.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q109_2 .
q:q109 pq:hasEvidence evid:ev_q109_2 .
