evid:ev_q118_1 a pq:Evidence ;
    pq:evidenceText """Os caminhos de migração constituem-se das fraturas, falhas, rochas carreadoras (rochas com porosidade e permeabilidade suficientes para permitir o transporte).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q118_1 .
q:q118 pq:hasEvidence evid:ev_q118_1 .
evid:ev_q118_1 pq:supportsQuestion q:q118 .

evid:ev_q118_2 a pq:Evidence ;
    pq:evidenceText """O petróleo gerado percorre estes caminhos até encontrar uma trapa.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q118_2 .
q:q118 pq:hasEvidence evid:ev_q118_2 .
evid:ev_q118_2 pq:supportsQuestion q:q118 .

evid:ev_q118_3 a pq:Evidence ;
    pq:evidenceText """Finalmente, estudos de migração revelam informação sobre como hidrocarbonetos movem-se da fonte ao reservatório e ajudam a quantificar a fonte (ou "a cozinha") dos hidrocarbonetos em uma área em particular.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q118_2 .
q:q118 pq:hasEvidence evid:ev_q118_3 .
evid:ev_q118_3 pq:supportsQuestion q:q118 .
