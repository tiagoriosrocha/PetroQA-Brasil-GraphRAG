evid:ev_q142_1 a pq:Evidence ;
    pq:evidenceText """O petróleo e gás natural são encontrados tanto em terra quanto no mar, principalmente nas bacias sedimentares (onde se encontram meios mais porosos - reservatórios), mas também em rochas do embasamento cristalino.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo | Wikipédia""" ;
    pq:fromSource src:s_q142_1 .
q:q142 pq:hasEvidence evid:ev_q142_1 .
evid:ev_q142_1 pq:supportsQuestion q:q142 .

evid:ev_q142_2 a pq:Evidence ;
    pq:evidenceText """Os hidrocarbonetos, portanto, ocupam espaços porosos nas rochas, sejam eles entre grãos ou fraturas.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo | Wikipédia""" ;
    pq:fromSource src:s_q142_2 .
q:q142 pq:hasEvidence evid:ev_q142_2 .
evid:ev_q142_2 pq:supportsQuestion q:q142 .

evid:ev_q142_3 a pq:Evidence ;
    pq:evidenceText """Possuem porosidade e permeabilidade, uma marcante estratificação e baixa resistência mecânica.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Rochas | SGB""" ;
    pq:fromSource src:s_q142_2 .
q:q142 pq:hasEvidence evid:ev_q142_3 .
evid:ev_q142_3 pq:supportsQuestion q:q142 .
