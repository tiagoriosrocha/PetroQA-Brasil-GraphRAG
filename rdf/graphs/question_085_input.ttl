evid:ev_q085_1 a pq:Evidence ;
    pq:evidenceText """O poço 1-BRSA-1390-RNS (Anhangá) está situado próximo à fronteira entre os estados do Ceará e do Rio Grande do Norte, a cerca de 190 km de Fortaleza e 250 km de Natal, em profundidade d’água de 2.196 metros, na Margem Equatorial brasileira.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petrobras descobre petróleo em águas ultraprofundas da Bacia Potiguar | Agência Petrobras""" ;
    pq:fromSource src:s_q085_1 .
q:q085 pq:hasEvidence evid:ev_q085_1 .
evid:ev_q085_1 pq:supportsQuestion q:q085 .

evid:ev_q085_2 a pq:Evidence ;
    pq:evidenceText """A maior parte da margem continental brasileira é uma clássica margem divergente formada pela ruptura do supercontinente Gondwana e o distanciamento das placas Sul-Americana e Africana.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Plataforma continental do Brasil | Wikipédia""" ;
    pq:fromSource src:s_q085_2 .
q:q085 pq:hasEvidence evid:ev_q085_2 .
evid:ev_q085_2 pq:supportsQuestion q:q085 .
