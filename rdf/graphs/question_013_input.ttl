evid:ev_q013_1 a pq:Evidence ;
    pq:evidenceText """Com essa separação, surgiram grandes depressões que deram origem a diversos lagos, que mais tarde foram conectados aos oceanos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q013_1 .
q:q013 pq:hasEvidence evid:ev_q013_1 .
evid:ev_q013_1 pq:supportsQuestion q:q013 .

evid:ev_q013_2 a pq:Evidence ;
    pq:evidenceText """Nas regiões mais profundas destes lagos começaram a acumular grandes quantidades de matéria orgânica de algas microscópicas.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q013_2 .
q:q013 pq:hasEvidence evid:ev_q013_2 .
evid:ev_q013_2 pq:supportsQuestion q:q013 .

evid:ev_q013_3 a pq:Evidence ;
    pq:evidenceText """Esta matéria orgânica, misturada a sedimentos, formou o que são as rochas que geram o óleo e o gás do pré-sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q013_2 .
q:q013 pq:hasEvidence evid:ev_q013_3 .
evid:ev_q013_3 pq:supportsQuestion q:q013 .

evid:ev_q013_4 a pq:Evidence ;
    pq:evidenceText """O ambiente de deposição consiste principalmente de lagos, deltas e bacias oceânicas.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q013_2 .
q:q013 pq:hasEvidence evid:ev_q013_4 .
evid:ev_q013_4 pq:supportsQuestion q:q013 .

evid:ev_q013_5 a pq:Evidence ;
    pq:evidenceText """O tipo de petróleo gerado depende do tipo de matéria orgânica: vegetais terrestres carreados tendem a gerar gás, enquanto que os plânctons tendem a gerar óleo.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q013_2 .
q:q013 pq:hasEvidence evid:ev_q013_5 .
evid:ev_q013_5 pq:supportsQuestion q:q013 .
