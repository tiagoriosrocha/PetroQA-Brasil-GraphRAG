evid:ev_q017_1 a pq:Evidence ;
    pq:evidenceText """Nas regiões mais profundas destes lagos começaram a acumular grandes quantidades de matéria orgânica de algas microscópicas.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q017_1 .
q:q017 pq:hasEvidence evid:ev_q017_1 .
evid:ev_q017_1 pq:supportsQuestion q:q017 .

evid:ev_q017_2 a pq:Evidence ;
    pq:evidenceText """Esta matéria orgânica, misturada a sedimentos, formou o que são as rochas que geram o óleo e o gás do pré-sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q017_2 .
q:q017 pq:hasEvidence evid:ev_q017_2 .
evid:ev_q017_2 pq:supportsQuestion q:q017 .

evid:ev_q017_3 a pq:Evidence ;
    pq:evidenceText """Nas partes mais rasas destes lagos, em grandes ilhas lacustres, surgiram as chamadas conchas calcárias que se acumularam cada vez mais com o passar do tempo.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q017_2 .
q:q017 pq:hasEvidence evid:ev_q017_3 .
evid:ev_q017_3 pq:supportsQuestion q:q017 .

evid:ev_q017_4 a pq:Evidence ;
    pq:evidenceText """Tanto as conchas calcárias quanto as rochas calcárias compõem os principais reservatórios do pré-sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q017_2 .
q:q017 pq:hasEvidence evid:ev_q017_4 .
evid:ev_q017_4 pq:supportsQuestion q:q017 .

evid:ev_q017_5 a pq:Evidence ;
    pq:evidenceText """Para que estas acumulações ocorram, necessita-se de rochas geradoras maduras, rocha reservatório, rocha selante e a sobrecarga.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q017_2 .
q:q017 pq:hasEvidence evid:ev_q017_5 .
evid:ev_q017_5 pq:supportsQuestion q:q017 .

evid:ev_q017_6 a pq:Evidence ;
    pq:evidenceText """Além da presença destas rochas, dois processos geológicos são fundamentais: a formação de trapas e a geração, migração e acumulação de hidrocarbonetos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q017_2 .
q:q017 pq:hasEvidence evid:ev_q017_6 .
evid:ev_q017_6 pq:supportsQuestion q:q017 .
