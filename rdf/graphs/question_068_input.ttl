evid:ev_q068_2 a pq:Evidence ;
    pq:evidenceText """Turbiditos são depósitos sedimentares originados por correntes de turbidez submarinas, sobretudo em bacias de antepaís (foreland), em ambiente tectônico de margem convergente (ativa).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Turbidito | Wikipédia""" ;
    pq:fromSource src:s_q068_2 .
q:q068 pq:hasEvidence evid:ev_q068_2 .
evid:ev_q068_2 pq:supportsQuestion q:q068 .

evid:ev_q068_3 a pq:Evidence ;
    pq:evidenceText """As sequências turbidíticas são muito procuradas pelos geólogos de petróleo por constituírem bons reservatórios para hidrocarbonetos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Turbidito | Wikipédia""" ;
    pq:fromSource src:s_q068_2 .
