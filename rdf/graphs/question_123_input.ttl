evid:ev_q123_2 a pq:Evidence ;
    pq:evidenceText """Turbiditos são depósitos sedimentares originados por correntes de turbidez submarinas, sobretudo em bacias de antepaís (foreland), em ambiente tectônico de margem convergente (ativa).""" ;
