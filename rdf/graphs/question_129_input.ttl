evid:ev_q129_1 a pq:Evidence ;
    pq:evidenceText """A Bacia de Santos é a maior bacia sedimentar marítima brasileira, com uma área total de mais de 350 mil quilômetros quadrados e que se estende de Cabo Frio (RJ) a Florianópolis (SC).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Quem Somos | Comunica Bacia de Santos | Petrobras""" ;
    pq:fromSource src:s_q129_1 .
