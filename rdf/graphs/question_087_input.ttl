src:s_q087_2 a pq:Source ;
    pq:sourceURL """https://publicacoesup.petrobras.com.br/peld/catalog/book/12/chapter/23""" ;
    pq:sourceIndex "2"^^xsd:integer .

evid:ev_q087_1 a pq:Evidence ;
    pq:evidenceText """A constatação de reservatórios turbidíticos de idade Albiana portador de petróleo é inédita na Bacia Potiguar e foi realizada através de perfis elétricos e amostras de óleo, que serão posteriormente caracterizados por meio de análises de laboratório.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petrobras descobre petróleo em águas ultraprofundas da Bacia Potiguar | Agência Petrobras""" ;
    pq:fromSource src:s_q087_1 .
q:q087 pq:hasEvidence evid:ev_q087_1 .
evid:ev_q087_1 pq:supportsQuestion q:q087 .

evid:ev_q087_2 a pq:Evidence ;
    pq:evidenceText """A Petrobras dará continuidade às atividades exploratórias na Concessão POT-M-762_R15, visando avaliar a qualidade dos reservatórios, as características do óleo e a viabilidade técnico-comercial da acumulação.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petrobras descobre petróleo em águas ultraprofundas da Bacia Potiguar | Agência Petrobras""" ;
    pq:fromSource src:s_q087_2 .
q:q087 pq:hasEvidence evid:ev_q087_2 .
evid:ev_q087_2 pq:supportsQuestion q:q087 .

evid:ev_q087_3 a pq:Evidence ;
    pq:evidenceText """Os desafios de caracterização desses reservatórios envolvem a integração dos estudos de sísmica, dados de poços, petrografia, interpretações de processos deposicionais e diagenéticos, assim como os resultados de testes de produtividade e injetividades das rochas.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Búzios: a jornada desde a caracterização dos reservatórios ao início do desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q087_2 .
q:q087 pq:hasEvidence evid:ev_q087_3 .
evid:ev_q087_3 pq:supportsQuestion q:q087 .
