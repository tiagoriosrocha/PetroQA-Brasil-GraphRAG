evid:ev_q149_1 a pq:Evidence ;
    pq:evidenceText """Ele é um líquido que ocorre entre os grãos de rochas sedimentares porosas e permeáveis, como arenitos, por exemplo, ou em cavidades interconectadas de rochas como calcário.""" ;
