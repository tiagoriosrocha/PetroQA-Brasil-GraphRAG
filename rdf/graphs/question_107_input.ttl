evid:ev_q107_1 a pq:Evidence ;
    pq:evidenceText """Conforme o diâmetro dos grãos desses sedimentos, eles podem ser, do maior para o menor: cascalho, areia, silte ou argila (conforme tabela a seguir).""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Rochas | SGB""" ;
    pq:fromSource src:s_q107_1 .
q:q107 pq:hasEvidence evid:ev_q107_1 .
evid:ev_q107_1 pq:supportsQuestion q:q107 .

evid:ev_q107_2 a pq:Evidence ;
    pq:evidenceText """Cascalhos formam conglomerados e brechas, areias formam arenitos, siltes formam siltitos e argilas formam argilitos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Rochas | SGB""" ;
    pq:fromSource src:s_q107_2 .
q:q107 pq:hasEvidence evid:ev_q107_2 .
evid:ev_q107_2 pq:supportsQuestion q:q107 .

evid:ev_q107_3 a pq:Evidence ;
    pq:evidenceText """Para a maioria dos geólogos, um turbidito é uma camada com gradação grano-classificada consistindo num conjunto de estratos arenito/pelito que foram depositados por corrente de turbidez e é comumente coberta por pelitos hemipelágicos contendo assembléia de fósseis de águas profundas.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Turbidito | Wikipédia""" ;
    pq:fromSource src:s_q107_2 .
q:q107 pq:hasEvidence evid:ev_q107_3 .
evid:ev_q107_3 pq:supportsQuestion q:q107 .
