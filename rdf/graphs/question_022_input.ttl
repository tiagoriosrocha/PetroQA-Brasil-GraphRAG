evid:ev_q022_1 a pq:Evidence ;
    pq:evidenceText """Nas partes mais rasas destes lagos, em grandes ilhas lacustres, surgiram as chamadas conchas calcárias que se acumularam cada vez mais com o passar do tempo.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q022_1 .
q:q022 pq:hasEvidence evid:ev_q022_1 .
evid:ev_q022_1 pq:supportsQuestion q:q022 .

evid:ev_q022_2 a pq:Evidence ;
    pq:evidenceText """Tanto as conchas calcárias quanto as rochas calcárias compõem os principais reservatórios do pré-sal.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal: mergulhe nessa jornada ultraprofunda | Petrobras""" ;
    pq:fromSource src:s_q022_2 .
q:q022 pq:hasEvidence evid:ev_q022_2 .
evid:ev_q022_2 pq:supportsQuestion q:q022 .

evid:ev_q022_3 a pq:Evidence ;
    pq:evidenceText """De um modo geral e amplo, as rochas sedimentares mais comuns podem ser divididas em arenosas (detríticas), argilosas (detríticas) e carbonatadas (não detríticas), estas últimas subdivididas em calcários e dolomitos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Rochas | SGB""" ;
    pq:fromSource src:s_q022_2 .
q:q022 pq:hasEvidence evid:ev_q022_3 .
evid:ev_q022_3 pq:supportsQuestion q:q022 .
