evid:ev_q131_1 a pq:Evidence ;
    pq:evidenceText """O pré-sal é uma formação rochosa localizada no subsolo da costa brasileira, que se estende entre os estados de Santa Catarina e Espírito Santo, atingindo uma área de cerca de 800 quilômetros de extensão por 200 quilômetros de largura.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Pré-sal Bacia de Santos | Comunica Bacia de Santos | Petrobras""" ;
    pq:fromSource src:s_q131_1 .
q:q131 pq:hasEvidence evid:ev_q131_1 .
evid:ev_q131_1 pq:supportsQuestion q:q131 .

evid:ev_q131_2 a pq:Evidence ;
    pq:evidenceText """Em 2007 a Petrobrás anunciou a descoberta de petróleo na camada denominada pré-sal, que posteriormente verificou-se ser um grande campo petrolífero, estendendo-se ao longo de 800 km na costa brasileira, do estado do Espírito Santo ao de Santa Catarina, abaixo de espessa camada de sal (rocha salina) e englobando as bacias sedimentares do Espírito Santo, de Campos e de Santos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Petróleo | Wikipédia""" ;
    pq:fromSource src:s_q131_2 .
q:q131 pq:hasEvidence evid:ev_q131_2 .
evid:ev_q131_2 pq:supportsQuestion q:q131 .
