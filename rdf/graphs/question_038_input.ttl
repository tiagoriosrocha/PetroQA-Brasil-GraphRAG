evid:ev_q038_1 a pq:Evidence ;
    pq:evidenceText """O primeiro poço perfurado na área, após a assinatura do contrato, foi o W731, que confirmou a continuidade dos reservatórios identificados no poço 2-ANP-2A-RJS, na porção Noroeste (NW) da estrutura de Libra.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Campo de Mero: caracterização dos reservatórios e desenvolvimento da produção | Universidade Petrobras""" ;
    pq:fromSource src:s_q038_1 .
q:q038 pq:hasEvidence evid:ev_q038_1 .
evid:ev_q038_1 pq:supportsQuestion q:q038 .

evid:ev_q038_2 a pq:Evidence ;
    pq:evidenceText """A condição para o armazenamento do petróleo nas rochas reservatório é a porosidade de tais rochas, que variam de 5% a 35%, tendo em média de 15% a 30%.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q038_2 .
q:q038 pq:hasEvidence evid:ev_q038_2 .
evid:ev_q038_2 pq:supportsQuestion q:q038 .
