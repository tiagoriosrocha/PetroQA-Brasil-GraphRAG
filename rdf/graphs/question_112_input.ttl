evid:ev_q112_1 a pq:Evidence ;
    pq:evidenceText """Além da presença destas rochas, dois processos geológicos são fundamentais: a formação de trapas e a geração, migração e acumulação de hidrocarbonetos.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q112_1 .
q:q112 pq:hasEvidence evid:ev_q112_1 .
evid:ev_q112_1 pq:supportsQuestion q:q112 .

evid:ev_q112_2 a pq:Evidence ;
    pq:evidenceText """Todas estas condições devem ocorrer de forma sincronizada em relação ao tempo geológico.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Sistema petrolífero | Wikipédia""" ;
    pq:fromSource src:s_q112_2 .
q:q112 pq:hasEvidence evid:ev_q112_2 .
evid:ev_q112_2 pq:supportsQuestion q:q112 .

evid:ev_q112_3 a pq:Evidence ;
    pq:evidenceText """Finalmente, estudos de migração revelam informação sobre como hidrocarbonetos movem-se da fonte ao reservatório e ajudam a quantificar a fonte (ou "a cozinha") dos hidrocarbonetos em uma área em particular.""" ;
    pq:evidenceRole """evidence""" ;
    pq:sourceTitle """Geologia do petróleo | Wikipédia""" ;
    pq:fromSource src:s_q112_2 .
q:q112 pq:hasEvidence evid:ev_q112_3 .
evid:ev_q112_3 pq:supportsQuestion q:q112 .
