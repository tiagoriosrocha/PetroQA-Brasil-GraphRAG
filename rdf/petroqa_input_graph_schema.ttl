@prefix pq: <https://w3id.org/petroqa-brasil/ontology/> .
@prefix res: <https://w3id.org/petroqa-brasil/resource/> .
@prefix q: <https://w3id.org/petroqa-brasil/question/> .
@prefix ent: <https://w3id.org/petroqa-brasil/entity/> .
@prefix evid: <https://w3id.org/petroqa-brasil/evidence/> .
@prefix src: <https://w3id.org/petroqa-brasil/source/> .
@prefix rel: <https://w3id.org/petroqa-brasil/relation/> .
@prefix geocore: <https://www.inf.ufrgs.br/bdi/ontologies/geocore.owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .


pq:Question a owl:Class .
pq:Evidence a owl:Class .
pq:Source a owl:Class .
pq:ReasoningStep a owl:Class .
pq:RelationAssertion a owl:Class .

pq:hasQuestionText a rdf:Property .
pq:hasInferenceType a rdf:Property .
pq:hasDifficulty a rdf:Property .
pq:requiresOntology a rdf:Property .
pq:hasRetrievalScope a rdf:Property .
pq:hasNumHops a rdf:Property .
pq:mentionsEntity a rdf:Property .
pq:hasReasoningStart a rdf:Property .
pq:hasReasoningEnd a rdf:Property .
pq:hasReasoningStep a rdf:Property .
pq:nextStep a rdf:Property .
pq:hasEvidence a rdf:Property .
pq:evidenceText a rdf:Property .
pq:evidenceRole a rdf:Property .
pq:fromSource a rdf:Property .
pq:sourceTitle a rdf:Property .
pq:sourceURL a rdf:Property .
pq:sourceIndex a rdf:Property .
pq:supportsQuestion a rdf:Property .
pq:hasRelation a rdf:Property .
pq:relationHead a rdf:Property .
pq:relationLabel a rdf:Property .
pq:relationTail a rdf:Property .
pq:pathPosition a rdf:Property .
pq:geoCoreClass a rdf:Property .
